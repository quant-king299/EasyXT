# ============================================
# Tushare 数据下载配置
# ============================================
# Tushare Pro Token (选填，如果使用Tushare数据源)
# 获取地址：https://tushare.pro/user/token
TUSHARE_TOKEN=your_tushare_token_here

# Tushare 备用Token (选填，限流时自动切换)
# 当主token被限流时会自动使用此token重试
TUSHARE_TOKEN_2=

# ============================================
# 数据存储路径配置
# ============================================
# 数据根目录（所有数据的存储位置）
# Windows示例：D:/StockData 或 E:/Data/Stock
# Linux/Mac示例：~/StockData 或 /mnt/data/Stock
# 说明：修改此路径后，所有数据都会存储在新位置
STOCK_DATA_ROOT=D:/StockData

# DuckDB 数据库路径（自动使用STOCK_DATA_ROOT）
# 一般不需要单独设置，会自动使用：{STOCK_DATA_ROOT}/stock_data.ddb
DUCKDB_PATH=D:/StockData/stock_data.ddb

# ============================================
# 雪球跟单配置
# ============================================
# 雪球登录Cookie（使用雪球跟单策略时必填）
# 获取方式：
#   1. 浏览器访问 https://xueqiu.com 并登录
#   2. F12 打开开发者工具 → 网络(Network)标签
#   3. 刷新页面，点击任意 xueqiu.com 请求
#   4. 在请求头中复制完整 Cookie 值
# 注意：Cookie 有时效性，过期后需重新获取
XUEQIU_COOKIE=

# ============================================
# miniQMT 自动登录配置
# ============================================
# QMT 可执行文件路径（XtMiniQmt.exe 完整路径）
# Windows 示例：D:\国金QMT交易端模拟\bin.x64\XtMiniQmt.exe
QMT_EXE_PATH=D:\国金QMT交易端模拟\bin.x64\XtMiniQmt.exe

# QMT 用户ID（资金账号）
QMT_USER_ID=

# QMT 登录密码
# ⚠️ 安全提醒：密码将以明文存储在 .env 文件中
# 建议：
#   1. 确保 .env 文件不被提交到版本控制系统（已在 .gitignore 中）
#   2. 不要在共享计算机上使用此功能
#   3. 定期修改密码
QMT_PASSWORD=

# QMT 数据目录（可选，用于清理临时文件）
# 通常在 QMT 安装目录的 userdata_mini 文件夹
# Windows 示例：D:\国金QMT交易端模拟\userdata_mini
QMT_DATA_DIR=

