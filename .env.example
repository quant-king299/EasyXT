# ============================================
# Tushare 数据下载配置
# ============================================
# Tushare Pro Token (必填)
# 获取地址：https://tushare.pro/user/token
TUSHARE_TOKEN=your_tushare_token_here

# ============================================
# DuckDB 数据库配置
# ============================================
# DuckDB 数据库路径
DUCKDB_PATH=D:/StockData/stock_data.ddb
