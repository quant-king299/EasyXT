# -*- coding: utf-8 -*-
"""
可转债回测引擎

纯 pandas 向量化回测，不依赖 backtrader。
适用于"每日调仓"型的组合回测策略（如低溢价率、双低策略等）。
"""

import pandas as pd
import numpy as np
from typing import Callable, Dict, Any
from .cb_data_manager import CBDataManager


class CBBactestEngine:
    """
    可转债组合回测引擎

    回测逻辑：
    1. 每个调仓日，根据策略选出 N 只可转债
    2. 等权买入
    3. 持有到下一个调仓日，重新选股调仓
    4. 计算组合净值曲线和各项指标
    """

    def __init__(self, db_path=None):
        self.data_mgr = CBDataManager(db_path)

    def run_backtest(
        self,
        strategy: Callable,
        start_date: str,
        end_date: str,
        rebalance_days: int = 1,
        top_n: int = 20,
        commission: float = 0.001,
        initial_cash: float = 100000.0,
        min_price: float = 100.0,
        max_price: float = 150.0,
        min_volume: float = 0,
        **strategy_kwargs
    ) -> Dict[str, Any]:
        """
        运行回测

        Args:
            strategy: 策略函数 (df_day, **kwargs) -> List[str]
            start_date: 开始日期
            end_date: 结束日期
            rebalance_days: 调仓频率（交易日数）
            top_n: 持仓数量
            commission: 单边交易费率
            initial_cash: 初始资金
            min_price: 最低价格过滤
            max_price: 最高价格过滤
            min_volume: 最低成交量过滤
        """
        df = self.data_mgr.get_cb_daily(start_date, end_date)
        if df.empty:
            return {'nav_curve': pd.DataFrame(), 'metrics': {},
                    'holdings_history': [], 'trades': []}

        df['trade_date'] = pd.to_datetime(df['trade_date'])
        df.sort_values(['trade_date', 'ts_code'], inplace=True)

        trading_dates = sorted(df['trade_date'].unique())

        cash = initial_cash
        holdings = {}
        nav_list = []
        holdings_history = []
        trades = []
        rebalance_counter = 0

        for i, date in enumerate(trading_dates):
            day_df = df[df['trade_date'] == date].copy()

            # 基本过滤
            mask = (day_df['close'] >= min_price) & (day_df['close'] <= max_price)
            if min_volume > 0:
                mask &= (day_df['vol'] >= min_volume)
            day_df_filtered = day_df[mask].copy()

            # 计算持仓市值
            holdings_value = 0.0
            for code, (shares, buy_price) in holdings.items():
                row = day_df[day_df['ts_code'] == code]
                if not row.empty:
                    holdings_value += shares * row.iloc[0]['close']
                else:
                    holdings_value += shares * buy_price

            total_value = cash + holdings_value
            nav = total_value / initial_cash

            rebalance_counter += 1
            should_rebalance = (rebalance_counter >= rebalance_days) or (i == 0)

            if should_rebalance and not day_df_filtered.empty:
                rebalance_counter = 0

                try:
                    selected = strategy(day_df_filtered, top_n=top_n, **strategy_kwargs)
                except Exception:
                    selected = []

                if not selected:
                    selected = day_df_filtered.nsmallest(top_n, 'cb_over_rate')['ts_code'].tolist()
                selected = selected[:top_n]

                # 卖出不在新组合的
                for code in [c for c in holdings if c not in selected]:
                    shares, buy_price = holdings[code]
                    row = day_df[day_df['ts_code'] == code]
                    sell_price = row.iloc[0]['close'] if not row.empty else buy_price
                    proceeds = shares * sell_price * (1 - commission)
                    cash += proceeds
                    trades.append({
                        'date': date, 'code': code, 'action': 'sell',
                        'price': sell_price, 'shares': shares,
                        'amount': proceeds, 'pnl': (sell_price - buy_price) * shares
                    })
                    del holdings[code]

                # 买入新入选的
                to_buy = [c for c in selected if c not in holdings]
                if to_buy:
                    target_per_stock = total_value / top_n if top_n > 0 else total_value
                    for code in to_buy:
                        row = day_df[day_df['ts_code'] == code]
                        if row.empty:
                            continue
                        buy_price = row.iloc[0]['close']
                        budget = min(target_per_stock, cash)
                        shares = int(budget / (buy_price * 10)) * 10
                        if shares <= 0:
                            continue
                        cost = shares * buy_price * (1 + commission)
                        if cost > cash:
                            shares = int(cash / (buy_price * 10 * (1 + commission))) * 10
                            cost = shares * buy_price * (1 + commission)
                        if shares > 0:
                            cash -= cost
                            holdings[code] = (shares, buy_price)
                            trades.append({
                                'date': date, 'code': code, 'action': 'buy',
                                'price': buy_price, 'shares': shares,
                                'amount': cost, 'pnl': 0
                            })

                holdings_history.append((date, list(holdings.keys())))

            nav_list.append({
                'date': date, 'nav': nav, 'cash': cash,
                'holdings_value': holdings_value,
                'total_value': total_value, 'num_holdings': len(holdings)
            })

        nav_df = pd.DataFrame(nav_list)
        if nav_df.empty:
            return {'nav_curve': nav_df, 'metrics': {},
                    'holdings_history': holdings_history, 'trades': trades}

        nav_df.set_index('date', inplace=True)
        nav_df['daily_return'] = nav_df['nav'].pct_change().fillna(0)

        return {
            'nav_curve': nav_df,
            'metrics': self._calc_metrics(nav_df, initial_cash),
            'holdings_history': holdings_history,
            'trades': trades
        }

    @staticmethod
    def _calc_metrics(nav_df: pd.DataFrame, initial_cash: float) -> Dict[str, Any]:
        if nav_df.empty or len(nav_df) < 2:
            return {}

        total_days = len(nav_df)
        total_return = nav_df['nav'].iloc[-1] - 1
        annual_return = (1 + total_return) ** (252 / max(total_days, 1)) - 1

        cummax = nav_df['nav'].cummax()
        drawdown = (nav_df['nav'] - cummax) / cummax
        max_drawdown = drawdown.min()

        daily_std = nav_df['daily_return'].std()
        sharpe = (nav_df['daily_return'].mean() / daily_std * np.sqrt(252)) if daily_std > 0 else 0

        calmar = annual_return / abs(max_drawdown) if max_drawdown != 0 else 0
        win_rate = (nav_df['daily_return'] > 0).sum() / total_days

        return {
            'total_return': total_return,
            'annual_return': annual_return,
            'max_drawdown': max_drawdown,
            'sharpe_ratio': sharpe,
            'calmar_ratio': calmar,
            'win_rate': win_rate,
            'total_days': total_days,
            'initial_cash': initial_cash,
            'final_value': nav_df['total_value'].iloc[-1],
        }
